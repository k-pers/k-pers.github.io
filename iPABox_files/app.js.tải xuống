function signIn() {
    var $ = this.$;
    var key = $$('input#key').val();
    var token = $$("input[name='_token']").val();
    var name = $$(".login-screen-title").text();

    // Save Key In LocalStorage
    localStorage.setItem(name, key);

    var x = fetch('/login/' + name + '/' + key, {
            method: 'GET',
            headers: {
                "Content-type": "application/json; charset=UTF-8",
                "X-CSRF-Token": token
            }
        })
        .then(response => {
            return response.text();
        })
        .then(response => {
            var arr = JSON.parse(response);
            if (arr[0] == "false") {
                $$('.block-footer').html(arr[1]);
            }
        })

    // there was an error her fixed it by change form main to current , i noticed error from console from app.views
    app.views.current.router.navigate('/login/' + name + '/' + key, {
        reloadCurrent: true,
        force: true
    });
}


function langLoad() {
    fetch('/storeLang', {
            method: 'GET'
        })
        .then(response => {
            return response.text();
        })
        .then(response => {
            $$('#app').html(response);

            var homeView = app.views.create('#view-home', {
                url: '/store/',
            });

            var infoView = app.views.create('#view-info', {
                url: '/info/'
            });

            var categoriesView = app.views.create('#view-categories', {
                url: '/categories/'
            });

            var settingsView = app.views.create('#view-search', {
                url: '/search/'
            });



        })
}


